/*******************************************************
 * Attendance Control Center
 *
 * Purpose:
 * - Custom menu: Attendance Control -> Generate Attendance File
 * - Reads Month / Year from ATTENDANCE_CONTROL
 * - Creates Attendance_<Month>_<Year> from Attendance template
 * - Blocks duplicate rows and duplicate Drive files
 * - Writes created file details back to ATTENDANCE_CONTROL
 * - Rebuilds script-managed protections on completed rows
 * - Installs mandatory installable onEdit triggers for the generated file
 *
 * REQUIRED TABS IN CONTROL CENTER:
 * 1) ATTENDANCE_CONTROL
 * 2) CONFIG
 *
 * REQUIRED CONFIG KEYS:
 * - TEMPLATE_ATTENDANCE_FILE_ID
 * - MONTHLY_ATTENDANCE_FOLDER_ID
 * - CONTROL_FILE_NAME
 *
 * REQUIRED ATTENDANCE_CONTROL HEADERS:
 * - PAYROLL_MONTH_KEY
 * - MONTH
 * - YEAR
 * - MONTHLY_ATTENDANCE_FILE_NAME
 * - MONTHLY_ATTENDANCE_FILE_ID
 * - CREATED_ON
 * - CREATED_BY
 * - REMARKS
 *******************************************************/

const ACC = Object.freeze({
  SHEETS: Object.freeze({
    ATTENDANCE_CONTROL: 'ATTENDANCE_CONTROL',
    CONFIG: 'CONFIG',
    META_DATA: 'META_DATA',
  }),

  INPUTS: Object.freeze({
    HEADER_ROW: 1,
    FIRST_DATA_ROW: 2,
  }),

  HEADERS: Object.freeze({
    PAYROLL_MONTH_KEY: 'PAYROLL_MONTH_KEY',
    MONTH: 'MONTH',
    YEAR: 'YEAR',
    MONTHLY_ATTENDANCE_FILE_NAME: 'MONTHLY_ATTENDANCE_FILE_NAME',
    MONTHLY_ATTENDANCE_FILE_ID: 'MONTHLY_ATTENDANCE_FILE_ID',
    CREATED_ON: 'CREATED_ON',
    CREATED_BY: 'CREATED_BY',
    REMARKS: 'REMARKS',
  }),

  CONFIG_KEYS: Object.freeze({
    TEMPLATE_ATTENDANCE_FILE_ID: 'TEMPLATE_ATTENDANCE_FILE_ID',
    MONTHLY_ATTENDANCE_FOLDER_ID: 'MONTHLY_ATTENDANCE_FOLDER_ID',
    CONTROL_FILE_NAME: 'CONTROL_FILE_NAME',
  }),

  TRIGGERS: Object.freeze({
    LEAVE_LEDGER: 'onEditLeaveLedgerAuto',
    RECOVERED_LEDGER: 'onEdit_RecoveredLedgerAuto_',
  }),

  OPTIONAL_META_KEYS: Object.freeze({
    PAYROLL_MONTH_LABEL: 'PAYROLL_MONTH_LABEL',
  }),

  PROTECTION: Object.freeze({
    DESCRIPTION_PREFIX: 'ACC_MANAGED_PROTECTION',
  }),
});

/*******************************************************
 * MENU
 *******************************************************/
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('Attendance Control')
    .addItem('Generate Attendance File', 'generateAttendanceFile')
    .addToUi();
}

/*******************************************************
 * MAIN - GENERATE ATTENDANCE FILE
 *******************************************************/
function generateAttendanceFile() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const lock = LockService.getScriptLock();

  const protectionContext = {
    sheet: null,
    headerMap: null,
    rowsToProtect: [],
    protectionsRemoved: false,
  };

  try {
    lock.waitLock(30000);
  } catch (e) {
    ui.alert(
      'Generate Attendance File',
      'Another attendance file generation is already running. Please wait a moment and try again.',
      ui.ButtonSet.OK
    );
    return;
  }

  try {
    const config = accGetConfigMap_();
    accValidateControlFileName_(ss, config);

    const sh = ss.getSheetByName(ACC.SHEETS.ATTENDANCE_CONTROL);
    if (!sh) throw new Error(`Sheet not found: ${ACC.SHEETS.ATTENDANCE_CONTROL}`);

    const headerMap = accGetHeaderMap_(sh, ACC.INPUTS.HEADER_ROW);
    protectionContext.sheet = sh;
    protectionContext.headerMap = headerMap;

    accValidateRequiredHeaders_(headerMap, [
      ACC.HEADERS.PAYROLL_MONTH_KEY,
      ACC.HEADERS.MONTH,
      ACC.HEADERS.YEAR,
      ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME,
      ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID,
      ACC.HEADERS.CREATED_ON,
      ACC.HEADERS.CREATED_BY,
      ACC.HEADERS.REMARKS,
    ]);

    const targetRow = accFindNextAttendanceInputRow_(sh, headerMap);
    if (!targetRow) {
      ui.alert(
        'Generate Attendance File',
        'No pending row found. Please enter MONTH and YEAR in a blank row first.',
        ui.ButtonSet.OK
      );
      return;
    }

    const existingFileName = String(sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME]).getDisplayValue() || '').trim();
    const existingFileId = String(sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID]).getDisplayValue() || '').trim();

    if (existingFileName || existingFileId) {
      ui.alert(
        'Generate Attendance File',
        `Row ${targetRow} already has an attendance file reference. Duplicate creation is blocked.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const monthYearVals = sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTH], 1, 2).getDisplayValues()[0];
    const month = String(monthYearVals[0] || '').trim();
    const year = String(monthYearVals[1] || '').trim();

    if (!month) {
      ui.alert(
        'Generate Attendance File',
        `Month is blank in row ${targetRow}. Please select Month in that row first.`,
        ui.ButtonSet.OK
      );
      return;
    }

    if (!year) {
      ui.alert(
        'Generate Attendance File',
        `Year is blank in row ${targetRow}. Please select Year in that row first.`,
        ui.ButtonSet.OK
      );
      return;
    }

    if (!/^\d{4}$/.test(year)) {
      ui.alert(
        'Generate Attendance File',
        `Year in row ${targetRow} must be a 4-digit value.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const payrollMonthKey = `${month}_${year}`;
    const fileName = `Attendance_${month}_${year}`;

    const duplicateCheck = accCheckDuplicateInAttendanceControl_(
      sh,
      headerMap,
      payrollMonthKey,
      fileName,
      month,
      year,
      targetRow
    );
    if (duplicateCheck.block) {
      ui.alert('Generate Attendance File', duplicateCheck.message, ui.ButtonSet.OK);
      return;
    }

    const attendanceFolderId = String(config[ACC.CONFIG_KEYS.MONTHLY_ATTENDANCE_FOLDER_ID] || '').trim();
    if (!attendanceFolderId) {
      throw new Error(`Missing CONFIG value: ${ACC.CONFIG_KEYS.MONTHLY_ATTENDANCE_FOLDER_ID}`);
    }

    if (accFolderHasExactFileName_(attendanceFolderId, fileName)) {
      ui.alert(
        'Generate Attendance File',
        `An attendance file named "${fileName}" already exists in the Monthly Attendance folder. Duplicate creation is blocked.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const templateFileId = String(config[ACC.CONFIG_KEYS.TEMPLATE_ATTENDANCE_FILE_ID] || '').trim();
    if (!templateFileId) {
      throw new Error(`Missing CONFIG value: ${ACC.CONFIG_KEYS.TEMPLATE_ATTENDANCE_FILE_ID}`);
    }

    const templateFile = DriveApp.getFileById(templateFileId);
    const attendanceFolder = DriveApp.getFolderById(attendanceFolderId);

    const copiedFile = templateFile.makeCopy(fileName, attendanceFolder);
    const copiedFileId = copiedFile.getId();
    const copiedSs = SpreadsheetApp.openById(copiedFileId);

    // Optional only: update existing metadata key if the copied template has META_DATA.
    // This does not create new sheets or new keys.
    accUpdateOptionalMetaDataKeys_(copiedSs, {
      [ACC.OPTIONAL_META_KEYS.PAYROLL_MONTH_LABEL]: payrollMonthKey,
    });

    // Mandatory: create installable onEdit triggers for the new attendance file.
    accInstallMandatoryAttendanceTriggers_(copiedSs);

    const createdOn = new Date();
    const createdBy = Session.getActiveUser().getEmail() || '';

    sh.getRange(targetRow, headerMap[ACC.HEADERS.PAYROLL_MONTH_KEY]).setValue(payrollMonthKey);
    sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME]).setValue(fileName);
    sh.getRange(targetRow, headerMap[ACC.HEADERS.CREATED_ON]).setValue(createdOn);
    sh.getRange(targetRow, headerMap[ACC.HEADERS.CREATED_BY]).setValue(createdBy);

    SpreadsheetApp.flush();

    sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID])
      .setFormula(`=HYPERLINK("https://docs.google.com/spreadsheets/d/${copiedFileId}/edit","${copiedFileId}")`);

    SpreadsheetApp.flush();

    const rowsToProtect = accGetProtectedRowsByFileName_(sh, headerMap);
    protectionContext.rowsToProtect = rowsToProtect;

    accRemoveScriptManagedProtections_(sh);
    protectionContext.protectionsRemoved = true;

    accRestoreManagedProtections_(sh, headerMap, rowsToProtect);
    protectionContext.protectionsRemoved = false;

    ui.alert(
      'Generate Attendance File',
      `Attendance file created successfully.\n\nFile Name: ${fileName}\nRow: ${targetRow}\n\nMandatory triggers installed:\n- ${ACC.TRIGGERS.LEAVE_LEDGER}\n- ${ACC.TRIGGERS.RECOVERED_LEDGER}`,
      ui.ButtonSet.OK
    );

  } catch (err) {
    try {
      if (
        protectionContext.protectionsRemoved &&
        protectionContext.sheet &&
        protectionContext.headerMap
      ) {
        accRestoreManagedProtections_(
          protectionContext.sheet,
          protectionContext.headerMap,
          protectionContext.rowsToProtect || []
        );
      }
    } catch (restoreErr) {
      // Keep original error as the main failure.
    }

    SpreadsheetApp.getUi().alert(
      'Generate Attendance File',
      `Error: ${err && err.message ? err.message : err}`,
      SpreadsheetApp.getUi().ButtonSet.OK
    );
  } finally {
    try {
      lock.releaseLock();
    } catch (e) {
      // no-op
    }
  }
}

/*******************************************************
 * CONTROL CENTER HELPERS
 *******************************************************/

function accGetConfigMap_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(ACC.SHEETS.CONFIG);
  if (!sh) throw new Error(`Sheet not found: ${ACC.SHEETS.CONFIG}`);

  const lastRow = sh.getLastRow();
  if (lastRow < 1) throw new Error('CONFIG sheet is empty.');

  const values = sh.getRange(1, 1, lastRow, 2).getDisplayValues();
  const map = {};

  for (let i = 0; i < values.length; i++) {
    const key = String(values[i][0] || '').trim();
    const value = String(values[i][1] || '').trim();
    if (key) map[key] = value;
  }

  return map;
}

function accValidateControlFileName_(ss, config) {
  const expectedName = String(config[ACC.CONFIG_KEYS.CONTROL_FILE_NAME] || '').trim();
  if (!expectedName) throw new Error(`Missing CONFIG value: ${ACC.CONFIG_KEYS.CONTROL_FILE_NAME}`);

  const actualName = String(ss.getName() || '').trim();
  if (actualName !== expectedName) {
    throw new Error(`This script must run from "${expectedName}" only. Current file: "${actualName}"`);
  }
}

function accGetHeaderMap_(sheet, headerRow) {
  const lastCol = sheet.getLastColumn();
  const headers = sheet.getRange(headerRow, 1, 1, lastCol).getDisplayValues()[0];
  const map = {};

  for (let c = 0; c < headers.length; c++) {
    const h = String(headers[c] || '').trim();
    if (h) map[h] = c + 1;
  }

  return map;
}

function accValidateRequiredHeaders_(headerMap, requiredHeaders) {
  const missing = requiredHeaders.filter(h => !headerMap[h]);
  if (missing.length) {
    throw new Error(`Missing required headers in ATTENDANCE_CONTROL: ${missing.join(', ')}`);
  }
}

function accFindNextAttendanceInputRow_(sheet, headerMap) {
  const lastRow = sheet.getLastRow();
  if (lastRow < ACC.INPUTS.FIRST_DATA_ROW) return null;

  const lastCol = sheet.getLastColumn();
  const data = sheet.getRange(
    ACC.INPUTS.FIRST_DATA_ROW,
    1,
    lastRow - ACC.INPUTS.HEADER_ROW,
    lastCol
  ).getDisplayValues();

  const monthCol = headerMap[ACC.HEADERS.MONTH] - 1;
  const yearCol = headerMap[ACC.HEADERS.YEAR] - 1;
  const fileNameCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME] - 1;
  const fileIdCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID] - 1;

  for (let i = 0; i < data.length; i++) {
    const month = String(data[i][monthCol] || '').trim();
    const year = String(data[i][yearCol] || '').trim();
    const fileName = String(data[i][fileNameCol] || '').trim();
    const fileId = String(data[i][fileIdCol] || '').trim();

    if (month && year && !fileName && !fileId) {
      return ACC.INPUTS.FIRST_DATA_ROW + i;
    }
  }

  return null;
}

function accCheckDuplicateInAttendanceControl_(sheet, headerMap, payrollMonthKey, fileName, month, year, skipRow) {
  const lastRow = sheet.getLastRow();
  if (lastRow < ACC.INPUTS.FIRST_DATA_ROW) {
    return { block: false, message: '' };
  }

  const lastCol = sheet.getLastColumn();
  const data = sheet.getRange(
    ACC.INPUTS.FIRST_DATA_ROW,
    1,
    lastRow - ACC.INPUTS.HEADER_ROW,
    lastCol
  ).getDisplayValues();

  const monthKeyCol = headerMap[ACC.HEADERS.PAYROLL_MONTH_KEY] - 1;
  const monthCol = headerMap[ACC.HEADERS.MONTH] - 1;
  const yearCol = headerMap[ACC.HEADERS.YEAR] - 1;
  const fileNameCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME] - 1;
  const fileIdCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID] - 1;

  const targetMonth = String(month || '').trim().toUpperCase();
  const targetYear = String(year || '').trim();

  for (let i = 0; i < data.length; i++) {
    const rowNum = ACC.INPUTS.FIRST_DATA_ROW + i;
    if (rowNum === skipRow) continue;

    const rowMonthKey = String(data[i][monthKeyCol] || '').trim();
    const rowMonth = String(data[i][monthCol] || '').trim().toUpperCase();
    const rowYear = String(data[i][yearCol] || '').trim();
    const rowFileName = String(data[i][fileNameCol] || '').trim();
    const rowFileId = String(data[i][fileIdCol] || '').trim();

    if (rowFileName === fileName) {
      return {
        block: true,
        message: `A row already exists for "${fileName}" in ATTENDANCE_CONTROL row ${rowNum}. Duplicate creation is blocked.`,
      };
    }

    if (rowMonthKey === payrollMonthKey) {
      return {
        block: true,
        message: `Attendance month "${payrollMonthKey}" already exists in ATTENDANCE_CONTROL row ${rowNum}. Duplicate creation is blocked.`,
      };
    }

    if (rowMonth === targetMonth && rowYear === targetYear && (rowFileName || rowFileId)) {
      return {
        block: true,
        message: `Attendance file already exists for ${month}_${year} in ATTENDANCE_CONTROL row ${rowNum}. Duplicate creation is blocked.`,
      };
    }
  }

  return { block: false, message: '' };
}

function accFolderHasExactFileName_(folderId, fileName) {
  const folder = DriveApp.getFolderById(folderId);
  const files = folder.getFilesByName(fileName);
  return files.hasNext();
}

function accUpdateOptionalMetaDataKeys_(spreadsheet, updates) {
  const sh = spreadsheet.getSheetByName(ACC.SHEETS.META_DATA);
  if (!sh) return;

  const lastRow = sh.getLastRow();
  if (lastRow < 1) return;

  const keys = sh.getRange(1, 1, lastRow, 2).getDisplayValues();
  const foundRows = {};

  for (let i = 0; i < keys.length; i++) {
    const key = String(keys[i][0] || '').trim();
    if (key) foundRows[key] = i + 1;
  }

  Object.keys(updates).forEach(key => {
    if (foundRows[key]) {
      sh.getRange(foundRows[key], 2).setValue(updates[key]);
    }
  });
}

function accInstallMandatoryAttendanceTriggers_(spreadsheet) {
  const targetId = spreadsheet.getId();
  const handlerNames = [
    ACC.TRIGGERS.LEAVE_LEDGER,
    ACC.TRIGGERS.RECOVERED_LEDGER,
  ];

  ScriptApp.getProjectTriggers().forEach(trigger => {
    const fn = trigger.getHandlerFunction ? trigger.getHandlerFunction() : '';
    const sourceId = accGetTriggerSourceIdSafe_(trigger);

    if (sourceId === targetId && handlerNames.indexOf(fn) !== -1) {
      ScriptApp.deleteTrigger(trigger);
    }
  });

  ScriptApp.newTrigger(ACC.TRIGGERS.LEAVE_LEDGER)
    .forSpreadsheet(spreadsheet)
    .onEdit()
    .create();

  ScriptApp.newTrigger(ACC.TRIGGERS.RECOVERED_LEDGER)
    .forSpreadsheet(spreadsheet)
    .onEdit()
    .create();
}

function accGetTriggerSourceIdSafe_(trigger) {
  try {
    return trigger.getTriggerSourceId ? trigger.getTriggerSourceId() : '';
  } catch (e) {
    return '';
  }
}

function accGetProtectedRowsByFileName_(sheet, headerMap) {
  const col = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME];
  const lastRow = sheet.getLastRow();
  if (lastRow < ACC.INPUTS.FIRST_DATA_ROW) return [];

  const values = sheet.getRange(
    ACC.INPUTS.FIRST_DATA_ROW,
    col,
    lastRow - ACC.INPUTS.HEADER_ROW,
    1
  ).getDisplayValues();

  const rows = [];
  for (let i = 0; i < values.length; i++) {
    const v = String(values[i][0] || '').trim();
    if (v) rows.push(ACC.INPUTS.FIRST_DATA_ROW + i);
  }

  return rows;
}

function accRemoveScriptManagedProtections_(sheet) {
  const protections = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);

  protections.forEach(protection => {
    const desc = String(protection.getDescription() || '');
    if (desc.indexOf(ACC.PROTECTION.DESCRIPTION_PREFIX) === 0) {
      protection.remove();
    }
  });
}

function accRestoreManagedProtections_(sheet, headerMap, rowNumbers) {
  const uniqueRows = Array.from(
    new Set((rowNumbers || []).filter(r => Number(r) >= ACC.INPUTS.FIRST_DATA_ROW))
  ).sort((a, b) => a - b);

  if (!uniqueRows.length) return;

  uniqueRows.forEach(rowNum => {
    accProtectRangeBlock_(
      sheet,
      rowNum,
      headerMap[ACC.HEADERS.PAYROLL_MONTH_KEY],
      headerMap[ACC.HEADERS.YEAR],
      `ROW_${rowNum}_A`
    );

    accProtectRangeBlock_(
      sheet,
      rowNum,
      headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME],
      headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID],
      `ROW_${rowNum}_B`
    );

    accProtectRangeBlock_(
      sheet,
      rowNum,
      headerMap[ACC.HEADERS.CREATED_ON],
      headerMap[ACC.HEADERS.CREATED_BY],
      `ROW_${rowNum}_C`
    );
  });
}

function accProtectRangeBlock_(sheet, rowNum, startCol, endCol, suffix) {
  if (!startCol || !endCol) return;

  const range = sheet.getRange(rowNum, startCol, 1, endCol - startCol + 1);
  const protection = range.protect();
  protection.setDescription(`${ACC.PROTECTION.DESCRIPTION_PREFIX}_${suffix}`);

  const me = Session.getEffectiveUser();
  const editors = protection.getEditors();
  if (editors.length) protection.removeEditors(editors);

  protection.addEditor(me);

  if (protection.canDomainEdit()) {
    protection.setDomainEdit(false);
  }
}

/*******************************************************
 * MANDATORY TRIGGER CODE - COPIED/ADAPTED FROM PROVIDED
 * ATT_14_RecoveredLedgerPush.gs AND ATT_15_LeaveLedgerPush.gs
 *
 * Important adaptation for Option 1:
 * These handlers run from Attendance Control Center triggers.
 * Therefore all push logic receives the event spreadsheet explicitly.
 *******************************************************/

/**********************
 * Source constants from ATT_00_Config and ATT_14
 **********************/
const ACC_LEAVE_MASTER_SPREADSHEET_ID = '1kVV5Vu8dPGdgGSAu7rZCz9I9L0XlJiQBE-Opv7izDfk';
const ACC_LEAVE_MASTER_SHEET_ID = 0;
const ACC_APPROVED_LEAVE_LEDGER_SHEET_ID = 1577916656;

const ACC_ATTENDANCE_SHEET_NAME = 'Attendance entry';
const ACC_SALARY_ADVANCE_DEDUCTIONS_SHEET_NAME = 'Salary Advance deductions';

const ACC_MASTER_SALARY_ADVANCE_SPREADSHEET_ID = '172uLkW5v1Dr_fYO8rZ3GaAwYEyYyRc_n0PaVYjHDwUg';
const ACC_MASTER_RECOVERED_LEDGER_SHEET_NAME = 'Recovered Amount Ledger';

/*******************************************************
 * Trigger 1: Recovered Ledger Push
 * Based on ATT_14_RecoveredLedgerPush.gs
 *******************************************************/
function onEdit_RecoveredLedgerAuto_(e) {
  try {
    if (!e || !e.range) return;

    const sh = e.range.getSheet();
    if (!sh || sh.getName() !== ACC_SALARY_ADVANCE_DEDUCTIONS_SHEET_NAME) return;

    const headerMap = accRecGetHeaderMapUpper_(sh);
    const payrollIdx0 = headerMap['PAYROLL STATUS'];
    if (payrollIdx0 == null) return;

    if (e.range.getColumn() !== payrollIdx0 + 1) return;

    const newVal = String(e.value || '').trim().toUpperCase();
    if (!newVal.startsWith('LOCKED')) return;

    const eventSpreadsheet = e.source || sh.getParent();
    accPushRecoveredLedgerSnapshot_(eventSpreadsheet);

  } catch (err) {
    // Silent for trigger safety, same behavior as provided source.
  }
}

function accPushRecoveredLedgerSnapshot_(spreadsheet) {
  const ss = spreadsheet;
  if (!ss) return;

  const attendanceFileName = ss.getName();
  const sh = ss.getSheetByName(ACC_SALARY_ADVANCE_DEDUCTIONS_SHEET_NAME);
  if (!sh) throw new Error(`Sheet not found: ${ACC_SALARY_ADVANCE_DEDUCTIONS_SHEET_NAME}`);

  const map = accRecGetHeaderMapUpper_(sh);

  const A = {
    month: accRecReqHeader_(map, 'MONTH'),
    emp: accRecReqHeader_(map, 'EMPLOYEE CODE'),
    name: accRecReqHeader_(map, 'NAME'),
    dept: accRecReqHeader_(map, 'DEPARTMENT'),
    ref: accRecReqHeader_(map, 'EMI REFERENCE NUMBER'),
    emiAmt: accRecReqHeader_(map, 'EMI AMOUNT'),
    curBal: accRecReqHeader_(map, 'CURRENT BALANCE'),
    hrDecision: accRecReqHeader_(map, 'HR DECISION'),
    recoveredAmt: accRecReqHeader_(map, 'RECOVERED AMOUNT'),
    payroll: accRecReqHeader_(map, 'PAYROLL STATUS'),
  };

  const lastRow = sh.getLastRow();
  if (lastRow < 2) return;

  const lastCol = sh.getLastColumn();
  const values = sh.getRange(2, 1, lastRow - 1, lastCol).getDisplayValues();

  const out = [];
  for (let i = 0; i < values.length; i++) {
    const r = values[i];

    const ref = String(r[A.ref] || '').trim();
    if (!ref) continue;

    const payroll = String(r[A.payroll] || '').trim().toUpperCase();
    if (!payroll.startsWith('LOCKED')) continue;

    out.push([
      attendanceFileName,
      r[A.month] || '',
      r[A.emp] || '',
      r[A.name] || '',
      r[A.dept] || '',
      ref,
      r[A.emiAmt] || '',
      r[A.curBal] || '',
      r[A.hrDecision] || '',
      r[A.recoveredAmt] || '',
    ]);
  }

  if (out.length === 0) return;

  const masterSS = SpreadsheetApp.openById(ACC_MASTER_SALARY_ADVANCE_SPREADSHEET_ID);
  const led = masterSS.getSheetByName(ACC_MASTER_RECOVERED_LEDGER_SHEET_NAME);
  if (!led) throw new Error(`Master sheet not found: ${ACC_MASTER_RECOVERED_LEDGER_SHEET_NAME}`);

  if (accRecAttendanceFileNameExistsInLedger_(led, attendanceFileName)) return;

  const startRow = accRecGetNextEmptyRowByColA_(led);
  const needLast = startRow + out.length - 1;

  if (led.getMaxRows() < needLast) {
    led.insertRowsAfter(led.getMaxRows(), needLast - led.getMaxRows());
  }

  led.getRange(startRow, 1, out.length, out[0].length).setValues(out);
}

function accRecGetHeaderMapUpper_(sh) {
  const lastCol = sh.getLastColumn();
  const headers = sh.getRange(1, 1, 1, lastCol).getDisplayValues()[0]
    .map(h => String(h || '').trim().toUpperCase());
  const map = {};
  headers.forEach((h, i) => { if (h) map[h] = i; });
  return map;
}

function accRecReqHeader_(map, name) {
  const key = String(name || '').trim().toUpperCase();
  if (!(key in map)) throw new Error(`Missing required header: ${name}`);
  return map[key];
}

function accRecGetNextEmptyRowByColA_(sh) {
  const maxRows = sh.getMaxRows();
  const colA = sh.getRange(1, 1, maxRows, 1).getDisplayValues();
  for (let i = colA.length - 1; i >= 0; i--) {
    if (String(colA[i][0] || '').trim() !== '') return i + 2;
  }
  return 2;
}

function accRecAttendanceFileNameExistsInLedger_(ledgerSheet, attendanceFileName) {
  const lastRow = ledgerSheet.getLastRow();
  if (lastRow < 2) return false;

  const colA = ledgerSheet.getRange(2, 1, lastRow - 1, 1).getDisplayValues();
  const target = String(attendanceFileName || '').trim();

  for (let i = 0; i < colA.length; i++) {
    if (String(colA[i][0] || '').trim() === target) return true;
  }
  return false;
}

/*******************************************************
 * Trigger 2: Leave Ledger Push
 * Based on ATT_15_LeaveLedgerPush.gs
 *******************************************************/
function onEditLeaveLedgerAuto(e) {
  try {
    if (!e || !e.range) return;

    const sh = e.range.getSheet();
    if (!sh || sh.getName() !== ACC_SALARY_ADVANCE_DEDUCTIONS_SHEET_NAME) return;

    const map = accLeaveGetHeaderMapUpper_(sh);
    const payrollIdx0 = map['PAYROLL STATUS'];
    if (payrollIdx0 == null) return;

    if (e.range.getColumn() !== payrollIdx0 + 1) return;

    const newVal = String(e.value || '').trim().toUpperCase();
    if (!newVal.includes('LOCKED')) return;

    const eventSpreadsheet = e.source || sh.getParent();
    accPushLeaveLedgerSnapshotAndUpdateBalances_(eventSpreadsheet);

  } catch (err) {
    // Silent for trigger safety, same behavior as provided source.
  }
}

function accPushLeaveLedgerSnapshotAndUpdateBalances_(spreadsheet) {
  const ss = spreadsheet;
  if (!ss) return;

  const attendanceFileName = String(ss.getName() || '').trim();
  const ym = accLeaveYearMonthFromAttendanceFileName_(attendanceFileName);
  if (!ym) return;

  const year = ym.year;
  const month = ym.month;

  const shEntry = ss.getSheetByName(ACC_ATTENDANCE_SHEET_NAME);
  if (!shEntry) throw new Error(`Sheet not found: ${ACC_ATTENDANCE_SHEET_NAME}`);

  const entryLastRow = shEntry.getLastRow();
  const entryLastCol = shEntry.getLastColumn();
  if (entryLastRow < 2 || entryLastCol < 1) return;

  const entryMap = accLeaveGetHeaderMapUpper_(shEntry);

  const A = {
    empCode: accLeaveReqHeader_(entryMap, 'EMPLOYEE CODE'),
    name: accLeaveReqHeader_(entryMap, 'NAME'),
    elEarn: accLeaveReqHeader_(entryMap, 'EL EARNED'),
    clEarn: accLeaveReqHeader_(entryMap, 'CL EARNED'),
    slEarn: accLeaveReqHeader_(entryMap, 'SL EARNED'),
    elBal: accLeaveReqHeader_(entryMap, 'EL BALANCE'),
    clBal: accLeaveReqHeader_(entryMap, 'CL BALANCE'),
    slBal: accLeaveReqHeader_(entryMap, 'SL BALANCE'),
    apEl: accLeaveReqHeader_(entryMap, 'APPROVED EL DAYS'),
    apCl: accLeaveReqHeader_(entryMap, 'APPROVED CL DAYS'),
    apSl: accLeaveReqHeader_(entryMap, 'APPROVED SL DAYS'),
    newEl: accLeaveReqHeader_(entryMap, 'NEW EL BALANCE'),
    newCl: accLeaveReqHeader_(entryMap, 'NEW CL BALANCE'),
    newSl: accLeaveReqHeader_(entryMap, 'NEW SL BALANCE'),
  };

  const entryVals = shEntry.getRange(2, 1, entryLastRow - 1, entryLastCol).getDisplayValues();

  const leaveSS = SpreadsheetApp.openById(ACC_LEAVE_MASTER_SPREADSHEET_ID);

  const shLedger = leaveSS.getSheetById(ACC_APPROVED_LEAVE_LEDGER_SHEET_ID);
  if (!shLedger) throw new Error(`Leave Master sheet not found by ID: ${ACC_APPROVED_LEAVE_LEDGER_SHEET_ID}`);

  const shMaster = leaveSS.getSheetById(ACC_LEAVE_MASTER_SHEET_ID);
  if (!shMaster) throw new Error(`Leave Master sheet not found by ID: ${ACC_LEAVE_MASTER_SHEET_ID}`);

  if (accLeaveLedgerHasYearMonth_(shLedger, year, month)) return;

  const mLastRow = shMaster.getLastRow();
  const mLastCol = shMaster.getLastColumn();
  if (mLastRow < 2 || mLastCol < 1) return;

  const mMap = accLeaveGetHeaderMapUpper_(shMaster);
  const M = {
    id: accLeaveReqHeader_(mMap, 'ID.NO'),
    category: accLeaveReqHeader_(mMap, 'CATEGORY'),

    elBal: accLeaveReqHeader_(mMap, 'EL BALANCE'),
    clBal: accLeaveReqHeader_(mMap, 'CL BALANCE'),
    slBal: accLeaveReqHeader_(mMap, 'SL BALANCE'),

    cfRem: accLeaveReqHeader_(mMap, 'EL_CF_REMAINING'),
    cfYear: accLeaveReqHeader_(mMap, 'EL_CF_YEAR'),
    janDone: accLeaveReqHeader_(mMap, 'EL_JAN_RESET_DONE_YEAR'),
    marDone: accLeaveReqHeader_(mMap, 'EL_MAR_EXPIRY_DONE_YEAR'),
  };

  const masterVals = shMaster.getRange(2, 1, mLastRow - 1, mLastCol).getDisplayValues();

  const masterById = new Map();
  for (let i = 0; i < masterVals.length; i++) {
    const id = String(masterVals[i][M.id] || '').trim();
    if (!id) continue;
    const cat = String(masterVals[i][M.category] || '').trim().toUpperCase();
    masterById.set(id, { idx0: i, category: cat });
  }

  let ledMap = accLeaveGetHeaderMapUpper_(shLedger);

  const requiredHeaders = [
    'ID.NO','NAME',
    'EL EARNED','CL EARNED','SL EARNED',
    'EL BALANCE','CL BALANCE','SL BALANCE',
    'APPROVED EL DAYS','APPROVED CL DAYS','APPROVED SL DAYS',
    'NEW EL BALANCE','NEW CL BALANCE','NEW SL BALANCE',
    'YEAR','MONTH',
    'EL_CF_USED','EL_CY_USED'
  ];

  let mutated = false;
  requiredHeaders.forEach(h => {
    if (ledMap[h] == null) {
      shLedger.getRange(1, shLedger.getLastColumn() + 1).setValue(h);
      mutated = true;
    }
  });
  if (mutated) ledMap = accLeaveGetHeaderMapUpper_(shLedger);

  const isDec = String(month || '').toUpperCase() === 'DEC';
  const isMar = String(month || '').toUpperCase() === 'MAR';
  const monthIdx = accLeaveMonthIndexFromAbbr_(month);
  const yNum = accLeaveToInt_(year);
  const nextYear = String((isNaN(yNum) ? '' : (yNum + 1)));
  const prevYear = String((isNaN(yNum) ? '' : (yNum - 1)));

  const outAligned = [];
  const updates = [];

  for (let i = 0; i < entryVals.length; i++) {
    const r = entryVals[i];

    const idKey = String(r[A.empCode] || '').trim();
    if (!idKey) continue;

    const info = masterById.get(idKey);
    if (!info || info.category !== 'STAFF') continue;

    const idx0 = info.idx0;
    const mRow = masterVals[idx0];

    const apElStr = r[A.apEl] || '';
    const newElStr = r[A.newEl] || '';
    const newClStr = r[A.newCl] || '';
    const newSlStr = r[A.newSl] || '';

    const cfRemBefore = accLeaveToNumber_(mRow[M.cfRem]);
    const cfYearVal = String(mRow[M.cfYear] || '').trim();
    const apElNum = accLeaveToNumber_(apElStr);

    const cfApplies = (cfYearVal && cfYearVal === prevYear && monthIdx >= 0 && monthIdx <= 2);
    const cfUsed = cfApplies ? Math.min(Math.max(cfRemBefore, 0), Math.max(apElNum, 0)) : 0;
    const cyUsed = Math.max(apElNum, 0) - cfUsed;

    const row = new Array(shLedger.getLastColumn()).fill('');
    accLeaveSetIfCol_(row, ledMap, 'ID.NO', idKey);
    accLeaveSetIfCol_(row, ledMap, 'NAME', r[A.name] || '');
    accLeaveSetIfCol_(row, ledMap, 'EL EARNED', r[A.elEarn] || '');
    accLeaveSetIfCol_(row, ledMap, 'CL EARNED', r[A.clEarn] || '');
    accLeaveSetIfCol_(row, ledMap, 'SL EARNED', r[A.slEarn] || '');
    accLeaveSetIfCol_(row, ledMap, 'EL BALANCE', r[A.elBal] || '');
    accLeaveSetIfCol_(row, ledMap, 'CL BALANCE', r[A.clBal] || '');
    accLeaveSetIfCol_(row, ledMap, 'SL BALANCE', r[A.slBal] || '');
    accLeaveSetIfCol_(row, ledMap, 'APPROVED EL DAYS', apElStr);
    accLeaveSetIfCol_(row, ledMap, 'APPROVED CL DAYS', r[A.apCl] || '');
    accLeaveSetIfCol_(row, ledMap, 'APPROVED SL DAYS', r[A.apSl] || '');
    accLeaveSetIfCol_(row, ledMap, 'NEW EL BALANCE', newElStr);
    accLeaveSetIfCol_(row, ledMap, 'NEW CL BALANCE', newClStr);
    accLeaveSetIfCol_(row, ledMap, 'NEW SL BALANCE', newSlStr);
    accLeaveSetIfCol_(row, ledMap, 'YEAR', year);
    accLeaveSetIfCol_(row, ledMap, 'MONTH', month);
    accLeaveSetIfCol_(row, ledMap, 'EL_CF_USED', accLeaveNumberToCell_(cfUsed));
    accLeaveSetIfCol_(row, ledMap, 'EL_CY_USED', accLeaveNumberToCell_(cyUsed));

    outAligned.push(row);

    updates.push({
      idx0: idx0,
      idKey: idKey,
      newEl: newElStr,
      newCl: newClStr,
      newSl: newSlStr,
      apElNum: apElNum,
      cfRemBefore: cfRemBefore,
      cfYearVal: cfYearVal,
      cfApplies: cfApplies,
      janDoneYear: String(mRow[M.janDone] || '').trim(),
      marDoneYear: String(mRow[M.marDone] || '').trim(),
      cfUsed: cfUsed,
      cyUsed: cyUsed,
    });
  }

  if (!outAligned.length) return;

  const startRow = accLeaveNextEmptyRowByColA_(shLedger);
  accLeaveEnsureRows_(shLedger, startRow + outAligned.length - 1);
  shLedger.getRange(startRow, 1, outAligned.length, outAligned[0].length).setValues(outAligned);

  const elRange = shMaster.getRange(2, M.elBal + 1, masterVals.length, 1);
  const clRange = shMaster.getRange(2, M.clBal + 1, masterVals.length, 1);
  const slRange = shMaster.getRange(2, M.slBal + 1, masterVals.length, 1);

  const cfRange = shMaster.getRange(2, M.cfRem + 1, masterVals.length, 1);
  const cfYearRange = shMaster.getRange(2, M.cfYear + 1, masterVals.length, 1);
  const janDoneRange = shMaster.getRange(2, M.janDone + 1, masterVals.length, 1);
  const marDoneRange = shMaster.getRange(2, M.marDone + 1, masterVals.length, 1);

  const elCol = elRange.getDisplayValues();
  const clCol = clRange.getDisplayValues();
  const slCol = slRange.getDisplayValues();

  const cfCol = cfRange.getDisplayValues();
  const cfYearCol = cfYearRange.getDisplayValues();
  const janDoneCol = janDoneRange.getDisplayValues();
  const marDoneCol = marDoneRange.getDisplayValues();

  let changed = false;

  for (const u of updates) {
    const j = u.idx0;
    if (j == null || j < 0 || j >= masterVals.length) continue;

    if (String(elCol[j][0] || '') !== String(u.newEl || '')) { elCol[j][0] = u.newEl; changed = true; }
    if (String(clCol[j][0] || '') !== String(u.newCl || '')) { clCol[j][0] = u.newCl; changed = true; }
    if (String(slCol[j][0] || '') !== String(u.newSl || '')) { slCol[j][0] = u.newSl; changed = true; }

    if (u.cfApplies) {
      const cfAfter = Math.max(0, (u.cfRemBefore || 0) - (u.cfUsed || 0));
      if (String(cfCol[j][0] || '') !== String(accLeaveNumberToCell_(cfAfter))) {
        cfCol[j][0] = accLeaveNumberToCell_(cfAfter);
        changed = true;
      }
    }

    if (isDec && nextYear && String(janDoneCol[j][0] || '').trim() !== nextYear) {
      if (String(clCol[j][0] || '') !== '0') { clCol[j][0] = '0'; changed = true; }
      if (String(slCol[j][0] || '') !== '0') { slCol[j][0] = '0'; changed = true; }

      const decClosingEl = accLeaveToNumber_(elCol[j][0]);
      if (String(cfCol[j][0] || '') !== String(accLeaveNumberToCell_(decClosingEl))) {
        cfCol[j][0] = accLeaveNumberToCell_(decClosingEl);
        changed = true;
      }
      if (String(cfYearCol[j][0] || '').trim() !== String(year)) {
        cfYearCol[j][0] = String(year);
        changed = true;
      }

      janDoneCol[j][0] = nextYear;
      changed = true;
    }

    if (isMar && String(marDoneCol[j][0] || '').trim() !== String(year)) {
      const cfYearVal = String(cfYearCol[j][0] || '').trim();
      const cfNow = accLeaveToNumber_(cfCol[j][0]);
      const elNow = accLeaveToNumber_(elCol[j][0]);

      const shouldExpire = (cfYearVal && cfYearVal === prevYear);

      if (shouldExpire && cfNow > 0) {
        const elAfterExpiry = elNow - cfNow;
        elCol[j][0] = accLeaveNumberToCell_(elAfterExpiry);
        cfCol[j][0] = '0';
        changed = true;
      }

      marDoneCol[j][0] = String(year);
      changed = true;
    }
  }

  if (changed) {
    elRange.setValues(elCol);
    clRange.setValues(clCol);
    slRange.setValues(slCol);

    cfRange.setValues(cfCol);
    cfYearRange.setValues(cfYearCol);
    janDoneRange.setValues(janDoneCol);
    marDoneRange.setValues(marDoneCol);
  }
}

function accLeaveLedgerHasYearMonth_(shLedger, year, month) {
  const map = accLeaveGetHeaderMapUpper_(shLedger);
  const yIdx0 = map['YEAR'];
  const mIdx0 = map['MONTH'];
  if (yIdx0 == null || mIdx0 == null) return false;

  const lastRow = shLedger.getLastRow();
  if (lastRow < 2) return false;

  const yVals = shLedger.getRange(2, yIdx0 + 1, lastRow - 1, 1).getDisplayValues();
  const mVals = shLedger.getRange(2, mIdx0 + 1, lastRow - 1, 1).getDisplayValues();

  const yT = String(year || '').trim();
  const mT = String(month || '').trim().toUpperCase();

  for (let i = yVals.length - 1; i >= 0; i--) {
    const y = String(yVals[i][0] || '').trim();
    const m = String(mVals[i][0] || '').trim().toUpperCase();
    if (!y && !m) continue;
    if (y === yT && m === mT) return true;
  }
  return false;
}

function accLeaveYearMonthFromAttendanceFileName_(fileName) {
  const m = String(fileName || '').trim().match(/^Attendance[_\-\s]+([A-Za-z]+)[_\-\s]+(\d{4})$/i);
  if (!m) return null;

  const mon = String(m[1] || '').trim().toLowerCase();
  const year = String(m[2] || '').trim();

  const idx = accLeaveMonthIndexFromName_(mon);
  if (idx < 0) return null;

  const abbr = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'][idx];
  return { year, month: abbr };
}

function accLeaveMonthIndexFromName_(monLower) {
  const months = [
    'january','february','march','april','may','june',
    'july','august','september','october','november','december'
  ];
  return months.indexOf(String(monLower || '').trim());
}

function accLeaveMonthIndexFromAbbr_(monAbbr) {
  const abbrs = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  return abbrs.indexOf(String(monAbbr || '').trim().toUpperCase());
}

function accLeaveGetHeaderMapUpper_(sh) {
  const lastCol = sh.getLastColumn();
  if (lastCol < 1) return {};
  const headers = sh.getRange(1, 1, 1, lastCol).getDisplayValues()[0]
    .map(h => String(h || '').trim().toUpperCase());
  const map = {};
  headers.forEach((h, i) => { if (h) map[h] = i; });
  return map;
}

function accLeaveReqHeader_(map, header) {
  const key = String(header || '').trim().toUpperCase();
  if (!(key in map)) throw new Error(`Missing required header: ${header}`);
  return map[key];
}

function accLeaveSetIfCol_(rowArr, map, header, value) {
  const idx0 = map[String(header || '').trim().toUpperCase()];
  if (idx0 != null) rowArr[idx0] = value;
}

function accLeaveNextEmptyRowByColA_(sh) {
  const maxRows = sh.getMaxRows();
  if (maxRows < 2) return 2;

  const colA = sh.getRange(1, 1, maxRows, 1).getDisplayValues();
  for (let i = colA.length - 1; i >= 0; i--) {
    if (String(colA[i][0] || '').trim() !== '') return i + 2;
  }
  return 2;
}

function accLeaveEnsureRows_(sh, neededLastRow) {
  const cur = sh.getMaxRows();
  if (cur < neededLastRow) sh.insertRowsAfter(cur, neededLastRow - cur);
}

function accLeaveToNumber_(v) {
  const s = String(v == null ? '' : v).replace(/,/g, '').trim();
  if (!s) return 0;
  const n = parseFloat(s);
  return isNaN(n) ? 0 : n;
}

function accLeaveToInt_(v) {
  const s = String(v == null ? '' : v).trim();
  const n = parseInt(s, 10);
  return isNaN(n) ? NaN : n;
}

function accLeaveNumberToCell_(n) {
  if (n == null || isNaN(n)) return '0';
  const x = Math.round(n * 1000000) / 1000000;
  return String(x);
}
