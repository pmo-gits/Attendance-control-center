const ACC = Object.freeze({
  SHEETS: Object.freeze({
    ATTENDANCE_CONTROL: 'ATTENDANCE_CONTROL',
    CONFIG: 'CONFIG',
    META_DATA: 'META_DATA',
  }),

  INPUTS: Object.freeze({
    HEADER_ROW: 1,
    FIRST_DATA_ROW: 2,
  }),

  HEADERS: Object.freeze({
    PAYROLL_MONTH_KEY: 'PAYROLL_MONTH_KEY',
    MONTH: 'MONTH',
    YEAR: 'YEAR',
    MONTHLY_ATTENDANCE_FILE_NAME: 'MONTHLY_ATTENDANCE_FILE_NAME',
    MONTHLY_ATTENDANCE_FILE_ID: 'MONTHLY_ATTENDANCE_FILE_ID',
    CREATED_ON: 'CREATED_ON',
    CREATED_BY: 'CREATED_BY',
    REMARKS: 'REMARKS',
  }),

  CONFIG_KEYS: Object.freeze({
    TEMPLATE_ATTENDANCE_FILE_ID: 'TEMPLATE_ATTENDANCE_FILE_ID',
    MONTHLY_ATTENDANCE_FOLDER_ID: 'MONTHLY_ATTENDANCE_FOLDER_ID',
    CONTROL_FILE_NAME: 'CONTROL_FILE_NAME',
  }),

  OPTIONAL_META_KEYS: Object.freeze({
    PAYROLL_MONTH_LABEL: 'PAYROLL_MONTH_LABEL',
  }),

  PROTECTION: Object.freeze({
    DESCRIPTION_PREFIX: 'ACC_MANAGED_PROTECTION',
  }),
});

function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('Attendance Control')
    .addItem('Generate Attendance File', 'generateAttendanceFile')
    .addToUi();
}

function generateAttendanceFile() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const lock = LockService.getScriptLock();

  const protectionContext = {
    sheet: null,
    headerMap: null,
    rowsToProtect: [],
    protectionsRemoved: false,
  };

  try {
    lock.waitLock(30000);
  } catch (e) {
    ui.alert(
      'Generate Attendance File',
      'Another attendance file generation is already running. Please wait a moment and try again.',
      ui.ButtonSet.OK
    );
    return;
  }

  try {
    const config = accGetConfigMap_();
    accValidateControlFileName_(ss, config);

    const sh = ss.getSheetByName(ACC.SHEETS.ATTENDANCE_CONTROL);
    if (!sh) throw new Error(`Sheet not found: ${ACC.SHEETS.ATTENDANCE_CONTROL}`);

    const headerMap = accGetHeaderMap_(sh, ACC.INPUTS.HEADER_ROW);

    protectionContext.sheet = sh;
    protectionContext.headerMap = headerMap;

    accValidateRequiredHeaders_(headerMap, [
      ACC.HEADERS.PAYROLL_MONTH_KEY,
      ACC.HEADERS.MONTH,
      ACC.HEADERS.YEAR,
      ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME,
      ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID,
      ACC.HEADERS.CREATED_ON,
      ACC.HEADERS.CREATED_BY,
      ACC.HEADERS.REMARKS,
    ]);

    const targetRow = accFindNextAttendanceInputRow_(sh, headerMap);

    if (!targetRow) {
      ui.alert(
        'Generate Attendance File',
        'No pending row found. Please enter MONTH and YEAR in a blank row first.',
        ui.ButtonSet.OK
      );
      return;
    }

    const existingFileName = String(
      sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME]).getDisplayValue() || ''
    ).trim();

    const existingFileId = String(
      sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID]).getDisplayValue() || ''
    ).trim();

    if (existingFileName || existingFileId) {
      ui.alert(
        'Generate Attendance File',
        `Row ${targetRow} already has an attendance file reference. Duplicate creation is blocked.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const monthYearVals = sh.getRange(
      targetRow,
      headerMap[ACC.HEADERS.MONTH],
      1,
      2
    ).getDisplayValues()[0];

    const month = String(monthYearVals[0] || '').trim();
    const year = String(monthYearVals[1] || '').trim();

    if (!month) {
      ui.alert(
        'Generate Attendance File',
        `Month is blank in row ${targetRow}. Please select Month in that row first.`,
        ui.ButtonSet.OK
      );
      return;
    }

    if (!year) {
      ui.alert(
        'Generate Attendance File',
        `Year is blank in row ${targetRow}. Please select Year in that row first.`,
        ui.ButtonSet.OK
      );
      return;
    }

    if (!/^\d{4}$/.test(year)) {
      ui.alert(
        'Generate Attendance File',
        `Year in row ${targetRow} must be a 4-digit value.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const payrollMonthKey = `${month}_${year}`;
    const fileName = `Attendance_${month}_${year}`;

    const duplicateCheck = accCheckDuplicateInAttendanceControl_(
      sh,
      headerMap,
      payrollMonthKey,
      fileName,
      month,
      year,
      targetRow
    );

    if (duplicateCheck.block) {
      ui.alert(
        'Generate Attendance File',
        duplicateCheck.message,
        ui.ButtonSet.OK
      );
      return;
    }

    const attendanceFolderId = String(
      config[ACC.CONFIG_KEYS.MONTHLY_ATTENDANCE_FOLDER_ID] || ''
    ).trim();

    if (!attendanceFolderId) {
      throw new Error(`Missing CONFIG value: ${ACC.CONFIG_KEYS.MONTHLY_ATTENDANCE_FOLDER_ID}`);
    }

    if (accFolderHasExactFileName_(attendanceFolderId, fileName)) {
      ui.alert(
        'Generate Attendance File',
        `An attendance file named "${fileName}" already exists in the Monthly Attendance folder. Duplicate creation is blocked.`,
        ui.ButtonSet.OK
      );
      return;
    }

    const templateFileId = String(
      config[ACC.CONFIG_KEYS.TEMPLATE_ATTENDANCE_FILE_ID] || ''
    ).trim();

    if (!templateFileId) {
      throw new Error(`Missing CONFIG value: ${ACC.CONFIG_KEYS.TEMPLATE_ATTENDANCE_FILE_ID}`);
    }

    const templateFile = DriveApp.getFileById(templateFileId);
    const attendanceFolder = DriveApp.getFolderById(attendanceFolderId);

    const copiedFile = templateFile.makeCopy(fileName, attendanceFolder);
    const copiedFileId = copiedFile.getId();
    const copiedSs = SpreadsheetApp.openById(copiedFileId);

    accUpdateOptionalMetaDataKeys_(copiedSs, {
      [ACC.OPTIONAL_META_KEYS.PAYROLL_MONTH_LABEL]: payrollMonthKey,
    });

    const createdOn = new Date();
    const createdBy = Session.getActiveUser().getEmail() || '';

    sh.getRange(targetRow, headerMap[ACC.HEADERS.PAYROLL_MONTH_KEY]).setValue(payrollMonthKey);
    sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME]).setValue(fileName);
    sh.getRange(targetRow, headerMap[ACC.HEADERS.CREATED_ON]).setValue(createdOn);
    sh.getRange(targetRow, headerMap[ACC.HEADERS.CREATED_BY]).setValue(createdBy);

    SpreadsheetApp.flush();

    sh.getRange(targetRow, headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID])
      .setFormula(`=HYPERLINK("https://docs.google.com/spreadsheets/d/${copiedFileId}/edit","${copiedFileId}")`);

    SpreadsheetApp.flush();

    const rowsToProtect = accGetProtectedRowsByFileName_(sh, headerMap);
    protectionContext.rowsToProtect = rowsToProtect;

    accRemoveScriptManagedProtections_(sh);
    protectionContext.protectionsRemoved = true;

    accRestoreManagedProtections_(sh, headerMap, rowsToProtect);
    protectionContext.protectionsRemoved = false;

    ui.alert(
      'Generate Attendance File',
      `Attendance file created successfully.\n\nFile Name: ${fileName}\nRow: ${targetRow}`,
      ui.ButtonSet.OK
    );

  } catch (err) {
    try {
      if (
        protectionContext.protectionsRemoved &&
        protectionContext.sheet &&
        protectionContext.headerMap
      ) {
        accRestoreManagedProtections_(
          protectionContext.sheet,
          protectionContext.headerMap,
          protectionContext.rowsToProtect || []
        );
      }
    } catch (restoreErr) {}

    SpreadsheetApp.getUi().alert(
      'Generate Attendance File',
      `Error: ${err && err.message ? err.message : err}`,
      SpreadsheetApp.getUi().ButtonSet.OK
    );

  } finally {
    try {
      lock.releaseLock();
    } catch (e) {}
  }
}

function accGetConfigMap_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(ACC.SHEETS.CONFIG);

  if (!sh) throw new Error(`Sheet not found: ${ACC.SHEETS.CONFIG}`);

  const lastRow = sh.getLastRow();

  if (lastRow < 1) {
    throw new Error('CONFIG sheet is empty.');
  }

  const values = sh.getRange(1, 1, lastRow, 2).getDisplayValues();
  const map = {};

  for (let i = 0; i < values.length; i++) {
    const key = String(values[i][0] || '').trim();
    const value = String(values[i][1] || '').trim();

    if (key) {
      map[key] = value;
    }
  }

  return map;
}

function accValidateControlFileName_(ss, config) {
  const expectedName = String(config[ACC.CONFIG_KEYS.CONTROL_FILE_NAME] || '').trim();

  if (!expectedName) {
    throw new Error(`Missing CONFIG value: ${ACC.CONFIG_KEYS.CONTROL_FILE_NAME}`);
  }

  const actualName = String(ss.getName() || '').trim();

  if (actualName !== expectedName) {
    throw new Error(`This script must run from "${expectedName}" only. Current file: "${actualName}"`);
  }
}

function accGetHeaderMap_(sheet, headerRow) {
  const lastCol = sheet.getLastColumn();

  const headers = sheet
    .getRange(headerRow, 1, 1, lastCol)
    .getDisplayValues()[0];

  const map = {};

  for (let c = 0; c < headers.length; c++) {
    const h = String(headers[c] || '').trim();

    if (h) {
      map[h] = c + 1;
    }
  }

  return map;
}

function accValidateRequiredHeaders_(headerMap, requiredHeaders) {
  const missing = requiredHeaders.filter(h => !headerMap[h]);

  if (missing.length) {
    throw new Error(`Missing required headers in ATTENDANCE_CONTROL: ${missing.join(', ')}`);
  }
}

function accFindNextAttendanceInputRow_(sheet, headerMap) {
  const lastRow = sheet.getLastRow();

  if (lastRow < ACC.INPUTS.FIRST_DATA_ROW) {
    return null;
  }

  const lastCol = sheet.getLastColumn();

  const data = sheet.getRange(
    ACC.INPUTS.FIRST_DATA_ROW,
    1,
    lastRow - ACC.INPUTS.HEADER_ROW,
    lastCol
  ).getDisplayValues();

  const monthCol = headerMap[ACC.HEADERS.MONTH] - 1;
  const yearCol = headerMap[ACC.HEADERS.YEAR] - 1;
  const fileNameCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME] - 1;
  const fileIdCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID] - 1;

  for (let i = 0; i < data.length; i++) {
    const month = String(data[i][monthCol] || '').trim();
    const year = String(data[i][yearCol] || '').trim();
    const fileName = String(data[i][fileNameCol] || '').trim();
    const fileId = String(data[i][fileIdCol] || '').trim();

    if (month && year && !fileName && !fileId) {
      return ACC.INPUTS.FIRST_DATA_ROW + i;
    }
  }

  return null;
}

function accCheckDuplicateInAttendanceControl_(sheet, headerMap, payrollMonthKey, fileName, month, year, skipRow) {
  const lastRow = sheet.getLastRow();

  if (lastRow < ACC.INPUTS.FIRST_DATA_ROW) {
    return { block: false, message: '' };
  }

  const lastCol = sheet.getLastColumn();

  const data = sheet.getRange(
    ACC.INPUTS.FIRST_DATA_ROW,
    1,
    lastRow - ACC.INPUTS.HEADER_ROW,
    lastCol
  ).getDisplayValues();

  const monthKeyCol = headerMap[ACC.HEADERS.PAYROLL_MONTH_KEY] - 1;
  const monthCol = headerMap[ACC.HEADERS.MONTH] - 1;
  const yearCol = headerMap[ACC.HEADERS.YEAR] - 1;
  const fileNameCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME] - 1;
  const fileIdCol = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID] - 1;

  const targetMonth = String(month || '').trim().toUpperCase();
  const targetYear = String(year || '').trim();

  for (let i = 0; i < data.length; i++) {
    const rowNum = ACC.INPUTS.FIRST_DATA_ROW + i;

    if (rowNum === skipRow) continue;

    const rowMonthKey = String(data[i][monthKeyCol] || '').trim();
    const rowMonth = String(data[i][monthCol] || '').trim().toUpperCase();
    const rowYear = String(data[i][yearCol] || '').trim();
    const rowFileName = String(data[i][fileNameCol] || '').trim();
    const rowFileId = String(data[i][fileIdCol] || '').trim();

    if (rowFileName === fileName) {
      return {
        block: true,
        message: `A row already exists for "${fileName}" in ATTENDANCE_CONTROL row ${rowNum}. Duplicate creation is blocked.`,
      };
    }

    if (rowMonthKey === payrollMonthKey) {
      return {
        block: true,
        message: `Attendance month "${payrollMonthKey}" already exists in ATTENDANCE_CONTROL row ${rowNum}. Duplicate creation is blocked.`,
      };
    }

    if (rowMonth === targetMonth && rowYear === targetYear && (rowFileName || rowFileId)) {
      return {
        block: true,
        message: `Attendance file already exists for ${month}_${year} in ATTENDANCE_CONTROL row ${rowNum}. Duplicate creation is blocked.`,
      };
    }
  }

  return { block: false, message: '' };
}

function accFolderHasExactFileName_(folderId, fileName) {
  const folder = DriveApp.getFolderById(folderId);
  const files = folder.getFilesByName(fileName);

  return files.hasNext();
}

function accUpdateOptionalMetaDataKeys_(spreadsheet, updates) {
  const sh = spreadsheet.getSheetByName(ACC.SHEETS.META_DATA);

  if (!sh) return;

  const lastRow = sh.getLastRow();

  if (lastRow < 1) return;

  const values = sh.getRange(1, 1, lastRow, 2).getDisplayValues();
  const foundRows = {};

  for (let i = 0; i < values.length; i++) {
    const key = String(values[i][0] || '').trim();

    if (key) {
      foundRows[key] = i + 1;
    }
  }

  Object.keys(updates).forEach(key => {
    if (foundRows[key]) {
      sh.getRange(foundRows[key], 2).setValue(updates[key]);
    }
  });
}

function accGetProtectedRowsByFileName_(sheet, headerMap) {
  const col = headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME];
  const lastRow = sheet.getLastRow();

  if (lastRow < ACC.INPUTS.FIRST_DATA_ROW) {
    return [];
  }

  const values = sheet.getRange(
    ACC.INPUTS.FIRST_DATA_ROW,
    col,
    lastRow - ACC.INPUTS.HEADER_ROW,
    1
  ).getDisplayValues();

  const rows = [];

  for (let i = 0; i < values.length; i++) {
    const v = String(values[i][0] || '').trim();

    if (v) {
      rows.push(ACC.INPUTS.FIRST_DATA_ROW + i);
    }
  }

  return rows;
}

function accRemoveScriptManagedProtections_(sheet) {
  const protections = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);

  protections.forEach(protection => {
    const desc = String(protection.getDescription() || '');

    if (desc.indexOf(ACC.PROTECTION.DESCRIPTION_PREFIX) === 0) {
      protection.remove();
    }
  });
}

function accRestoreManagedProtections_(sheet, headerMap, rowNumbers) {
  const uniqueRows = Array.from(
    new Set((rowNumbers || []).filter(r => Number(r) >= ACC.INPUTS.FIRST_DATA_ROW))
  ).sort((a, b) => a - b);

  if (!uniqueRows.length) return;

  uniqueRows.forEach(rowNum => {
    accProtectRangeBlock_(
      sheet,
      rowNum,
      headerMap[ACC.HEADERS.PAYROLL_MONTH_KEY],
      headerMap[ACC.HEADERS.YEAR],
      `ROW_${rowNum}_A`
    );

    accProtectRangeBlock_(
      sheet,
      rowNum,
      headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_NAME],
      headerMap[ACC.HEADERS.MONTHLY_ATTENDANCE_FILE_ID],
      `ROW_${rowNum}_B`
    );

    accProtectRangeBlock_(
      sheet,
      rowNum,
      headerMap[ACC.HEADERS.CREATED_ON],
      headerMap[ACC.HEADERS.CREATED_BY],
      `ROW_${rowNum}_C`
    );
  });
}

function accProtectRangeBlock_(sheet, rowNum, startCol, endCol, suffix) {
  if (!startCol || !endCol) return;

  const range = sheet.getRange(rowNum, startCol, 1, endCol - startCol + 1);
  const protection = range.protect();

  protection.setDescription(`${ACC.PROTECTION.DESCRIPTION_PREFIX}_${suffix}`);

  const me = Session.getEffectiveUser();
  const editors = protection.getEditors();

  if (editors.length) {
    protection.removeEditors(editors);
  }

  protection.addEditor(me);

  if (protection.canDomainEdit()) {
    protection.setDomainEdit(false);
  }
}
